<svg width="400" height="600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a0b2e;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#4a1c6e;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#2d1b4e;stop-opacity:1" />
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <rect width="400" height="600" fill="url(#grad1)" rx="20" ry="20"/>
  <rect x="10" y="10" width="380" height="580" fill="none" stroke="#d4af37" stroke-width="3" rx="15" ry="15" filter="url(#glow)"/>
  
  <circle cx="30" cy="30" r="8" fill="#d4af37" opacity="0.8"/>
  <circle cx="370" cy="30" r="8" fill="#d4af37" opacity="0.8"/>
  <circle cx="30" cy="570" r="8" fill="#d4af37" opacity="0.8"/>
  <circle cx="370" cy="570" r="8" fill="#d4af37" opacity="0.8"/>
  
  <ellipse cx="200" cy="220" rx="70" ry="50" fill="none" stroke="#d4af37" stroke-width="2" opacity="0.7"/>
  <circle cx="200" cy="220" r="30" fill="#d4af37" opacity="0.3"/>
  <circle cx="200" cy="220" r="12" fill="#d4af37" opacity="0.9"/>
  
  <line x1="200" y1="170" x2="200" y2="120" stroke="#d4af37" stroke-width="2" opacity="0.5"/>
  <line x1="200" y1="270" x2="200" y2="320" stroke="#d4af37" stroke-width="2" opacity="0.5"/>
  <line x1="150" y1="220" x2="100" y2="220" stroke="#d4af37" stroke-width="2" opacity="0.5"/>
  <line x1="250" y1="220" x2="300" y2="220" stroke="#d4af37" stroke-width="2" opacity="0.5"/>
  
  <text x="200" y="380" font-family="Georgia, serif" font-size="26" fill="#d4af37" text-anchor="middle" font-weight="bold">HASTY</text>
  <text x="200" y="410" font-family="Georgia, serif" font-size="26" fill="#d4af37" text-anchor="middle" font-weight="bold">GENERALIZATION</text>
  <text x="200" y="450" font-family="Georgia, serif" font-size="14" fill="#e0e0e0" text-anchor="middle" opacity="0.8">The Fool's Rush</text>
  
  <path d="M 140 500 Q 200 530 260 500" fill="none" stroke="#d4af37" stroke-width="2" opacity="0.6"/>
  <circle cx="140" cy="500" r="5" fill="#d4af37" opacity="0.6"/>
  <circle cx="200" cy="520" r="5" fill="#d4af37" opacity="0.6"/>
  <circle cx="260" cy="500" r="5" fill="#d4af37" opacity="0.6"/>
  
  <text x="200" y="560" font-family="Georgia, serif" font-size="12" fill="#d4af37" text-anchor="middle" opacity="0.5">Fallacy Tarot Deck</text>
</svg>
